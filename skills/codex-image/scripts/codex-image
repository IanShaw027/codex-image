#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

pick_python() {
  local candidate=""
  local -a candidates=()

  if [[ -n "${CODEX_IMAGE_PYTHON:-}" ]]; then
    candidates+=("${CODEX_IMAGE_PYTHON}")
  fi
  candidates+=(
    /opt/homebrew/bin/python3.13
    python3.13
    /opt/homebrew/bin/python3.12
    python3.12
    /opt/homebrew/bin/python3.11
    python3.11
    python3
    python
  )

  for candidate in "${candidates[@]}"; do
    if [[ -z "${candidate}" ]]; then
      continue
    fi
    if [[ "${candidate}" == */* ]]; then
      [[ -x "${candidate}" ]] || continue
    elif ! command -v "${candidate}" >/dev/null 2>&1; then
      continue
    fi

    if "${candidate}" -c 'import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 11) else 1)' >/dev/null 2>&1; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

if ! selected_python="$(pick_python)"; then
  printf '%s\n' "python 3.11+ is required for codex-image. Set CODEX_IMAGE_PYTHON or install python3.11+." >&2
  exit 1
fi

exec "$selected_python" "$SCRIPT_DIR/codex_image.py" "$@"
